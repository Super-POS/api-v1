PORT=3000

# Comma-separated browser origins allowed to call the API (SPA URL(s), incl. scheme; port only if non-default).
# Docker / VM example (adjust hostnames/IP):
#   CORS_ORIGINS=http://localhost,http://34.142.211.96,http://pos.navahub.org,https://pos.navahub.org
CORS_ORIGINS=

DB_CONNECTION=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=pos
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_TIMEZONE=Asia/Phnom_Penh

# Base URL the API uses to POST uploads. Must be reachable from the API process. The browser uses the same
# file host in web-v1 FILE_BASE_URL to display images; keep both aligned with the public file server URL.
FILE_BASE_URL=http://localhost:9006

# Baray (https://dash.baray.io) — bank / QR payments. Webhook: POST /api/webhooks/baray (no JWT).
#
# Local HTTPS tunnel (Baray webhooks require a public URL):
#   Cloudflare (recommended):  cd api-v1 && npm run tunnel        (host API, PORT default 3000)
#                              cd api-v1 && npm run tunnel:docker (API on host port 9003)
#   ngrok (legacy):            npm run ngrok | npm run ngrok:docker
# 3) Copy the https URL printed by cloudflared (e.g. https://xyz.trycloudflare.com) and set in Baray:
#    Success Webhook Callback URL = {that URL}/api/webhooks/baray
# 4) URL changes every time you restart the quick tunnel — update the Baray dashboard again.
# After pulling code that adds order status "awaiting_payment" (Baray gating), run on Postgres if needed:
#   ALTER TYPE enum_order_status ADD VALUE IF NOT EXISTS 'awaiting_payment';
#
# Public Key from Baray dashboard → API key (header x-api-key)
BARAY_API_KEY=
# Secret Key from dashboard → encryption key SK (base64, 32 bytes when decoded)
BARAY_SK=
# Cipher Key from dashboard → IV (base64, 16 bytes when decoded)
BARAY_IV=
# Full pay URL (default https://api.baray.io/pay)
BARAY_PAY_URL=https://api.baray.io/pay
# Customer pay page (Baray /pay often returns only intent id; URL becomes {BASE}/{_id}, see baray.io docs)
BARAY_CHECKOUT_BASE_URL=https://pay.baray.io
BARAY_CURRENCY=USD
# Decimal places for amount string (e.g. 2 for USD, 0 for whole KHR)
BARAY_AMOUNT_DECIMALS=2

JWT_SECRET=replace-with-a-long-random-string

JS_BASE_URL=
JS_USERNAME=
JS_PASSWORD=
JS_TEMPLATE=/Invoice/main
JS_TEMPLATE_POS=/report_sale/pdf/main
JS_TEMPLATE_CASHIER=/report_cashier/main
JS_TEMPLATE_PRODUCT=/report_product/pdf/main
JS_TEMPLATE_SALE_EXCEL=/report_sale/excel/sale-excel
JS_TEMPLATE_PRODUCT_EXCEL=/report_product/excel/product-excel

# ── Two Telegram bots (create both in @BotFather) ─────────────────────────────
#
# 1) CASHIER / OPS — posts new orders & cancellations to your staff group.
#    Add this bot to the group, then set TELEGRAM_CASHIER_CHAT_ID to that group id.
TELEGRAM_CASHIER_BOT_TOKEN=
TELEGRAM_CASHIER_CHAT_ID=
# Legacy names (still supported):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
#
# 2) CUSTOMER — Mini App, /start in telegram-mini-app, shopper DMs, login widget.
#    Must match telegram-mini-app BOT_TOKEN and customer_web NEXT_PUBLIC_TELEGRAM_LOGIN_BOT username.
TELEGRAM_CUSTOMER_BOT_TOKEN=
# Legacy name (still supported):
TELEGRAM_WEBAPP_BOT_TOKEN=
#
# Shared secret: telegram-mini-app → POST /api/account/auth/telegram-bot
TELEGRAM_BOT_SERVER_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Bakong KHQR (NBC Open API). Docs: https://api-bakong.nbc.gov.kh/document
# BAKONG_TOKEN — 1-year JWT from developer portal; renewed via BAKONG_EMAIL when expired.
# BAKONG_MERCHANT_ID — e.g. yourstore@bkrt (must match the token's merchant).
# BAKONG_CURRENCY — USD or KHR (order totals are KHR; converted when USD).
#
# GCP / datacenter VMs: NBC CloudFront often blocks cloud IPs. Symptom: orders stay
# awaiting_payment after the customer paid. Run ./scripts/gcp-bakong-network-check.sh on the VM.
# Fix: reserve a static egress IP, ask NBC to whitelist it for Merchant Open API, or set:
# BAKONG_HTTP_PROXY=http://user:pass@proxy-host:port
# BAKONG_BASE_URL=https://api-bakong.nbc.gov.kh
BAKONG_TOKEN=
BAKONG_EMAIL=
BAKONG_MERCHANT_ID=
BAKONG_CURRENCY=USD
BAKONG_QR_EXPIRY_MINUTES=10

# Google Calendar (Service Account) — for meeting room booking sync.
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON — paste the entire service account JSON key as a single-line string.
# GOOGLE_CALENDAR_ID — the calendar to write events to (e.g. your-email@gmail.com or a shared calendar ID).
#   The service account must be granted "Make changes to events" permission on this calendar.
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
GOOGLE_CALENDAR_ID=primary
