PORT=3000

DB_CONNECTION=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=pos
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_TIMEZONE=Asia/Phnom_Penh

# Base URL the API uses to POST uploads. Must be reachable from the API process. The browser uses the same
# file host in web-v1 FILE_BASE_URL to display images; keep both aligned with the public file server URL.
FILE_BASE_URL=http://localhost:9006

# Baray (https://dash.baray.io) — bank / QR payments. Webhook: POST /api/webhooks/baray (no JWT).
#
# Local + ngrok:
#   - API on host (npm start:dev):  npm run ngrok   (tunnels PORT or 3000)
#   - API in Docker (host 9003→container 3000):  npm run ngrok:docker
# 3) Copy the https URL from ngrok (e.g. https://abc123.ngrok-free.app) and set in Baray dashboard:
#    Success Webhook Callback URL = {that URL}/api/webhooks/baray
#    Success Client Redirect = {that URL or http://localhost:4444/...} per Baray rules.
# 4) If the ngrok URL changes, update the dashboard again.
# After pulling code that adds order status "awaiting_payment" (Baray gating), run on Postgres if needed:
#   ALTER TYPE enum_order_status ADD VALUE IF NOT EXISTS 'awaiting_payment';
#
# Public Key from Baray dashboard → API key (header x-api-key)
BARAY_API_KEY=
# Secret Key from dashboard → encryption key SK (base64, 32 bytes when decoded)
BARAY_SK=
# Cipher Key from dashboard → IV (base64, 16 bytes when decoded)
BARAY_IV=
# Full pay URL (default https://api.baray.io/pay)
BARAY_PAY_URL=https://api.baray.io/pay
# Customer pay page (Baray /pay often returns only intent id; URL becomes {BASE}/{_id}, see baray.io docs)
BARAY_CHECKOUT_BASE_URL=https://pay.baray.io
BARAY_CURRENCY=USD
# Decimal places for amount string (e.g. 2 for USD, 0 for whole KHR)
BARAY_AMOUNT_DECIMALS=2

JWT_SECRET=replace-with-a-long-random-string

JS_BASE_URL=
JS_USERNAME=
JS_PASSWORD=
JS_TEMPLATE=/Invoice/main
JS_TEMPLATE_POS=/report_sale/pdf/main
JS_TEMPLATE_CASHIER=/report_cashier/main
JS_TEMPLATE_PRODUCT=/report_product/pdf/main
JS_TEMPLATE_SALE_EXCEL=/report_sale/excel/sale-excel
JS_TEMPLATE_PRODUCT_EXCEL=/report_product/excel/product-excel

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
